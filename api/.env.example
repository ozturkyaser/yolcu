PORT=4000
DATABASE_URL=postgresql://yol:yol_dev_change_me@localhost:5432/yol
JWT_SECRET=change-me-to-a-long-random-string-in-production
CORS_ORIGIN=http://localhost:5173
# Optional: npm run dev / Docker-API (NODE_ENV=production): localhost mit beliebigem Port erlauben
# CORS_RELAX_LOCALHOST=true
INIT_DB=true
# Optional: Karten-Simulation – 5 Nutzer (sim-*@yol.local / sim123456), 3 Gruppen, Positionen um Berlin (idempotent)
# SEED_MAP_SIMULATION=true
# Optional: eigener OSRM-Server (Standard: öffentlicher OSRM-Demo, nur für Entwicklung)
# OSRM_URL=https://router.project-osrm.org
# Pflicht für Nominatim (Ortssuche): gültiger User-Agent mit Kontakt (OSM-Richtlinie)
# GEOCODING_USER_AGENT=YolArkadasim/1.0 (kontakt@deine-domain.example)
# KI / OpenAI-kompatible Chat-Completions (Navigation, Gruppenchat-KI, Route-Briefing)
# Empfohlen: einheitlich AI_* (überschreibt OPENAI_* falls beides gesetzt ist)
# AI_API_KEY=sk-...
# AI_MODEL=gpt-4o-mini
# AI_BASE_URL=https://api.openai.com/v1
# AI_TIMEOUT_MS=30000
# Optional: Gruppenchat-Auszug für KI (Anzahl Nachrichten von hinten)
# AI_GROUP_CHAT_MAX_MESSAGES=60
# Abwärtskompatibel:
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# Nach Migration (INIT_DB): Testnutzer test@yol.local / testtest12 (nur Entwicklung)
# Optional: Speicher für Sprachnachrichten (Standard: ./data/voice relativ zum API-Arbeitsverzeichnis)
# VOICE_STORAGE_DIR=/app/data/voice

# --- Vignetten: Stripe-Checkout (optional) ---
# STRIPE_SECRET_KEY=sk_test_...
# Öffentliche Web-URL für Stripe-Redirect (ohne trailing slash), z. B. Vite oder Produktions-Domain
# PUBLIC_WEB_APP_URL=http://localhost:5173

# --- Vignetten: E-Mail (optional, SMTP) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM="Yol <noreply@example.com>"
# Neue Anfrage: Benachrichtigung an Admin (eine Adresse)
# VIGNETTE_ADMIN_EMAIL=admin@example.com
# Alternative Variable (falls VIGNETTE_ADMIN_EMAIL leer):
# MAIL_ADMIN_NOTIFY=admin@example.com
