PORT=4000
DATABASE_URL=postgresql://yol:yol_dev_change_me@localhost:5432/yol
JWT_SECRET=change-me-to-a-long-random-string-in-production
CORS_ORIGIN=http://localhost:5173
# Optional: npm run dev / Docker-API (NODE_ENV=production): localhost mit beliebigem Port erlauben
# CORS_RELAX_LOCALHOST=true
INIT_DB=true
# Optional: eigener OSRM-Server (Standard: öffentlicher OSRM-Demo, nur für Entwicklung)
# OSRM_URL=https://router.project-osrm.org
# Pflicht für Nominatim (Ortssuche): gültiger User-Agent mit Kontakt (OSM-Richtlinie)
# GEOCODING_USER_AGENT=YolArkadasim/1.0 (kontakt@deine-domain.example)
# Nach Migration (INIT_DB): Testnutzer test@yol.local / testtest12 (nur Entwicklung)
# Optional: Speicher für Sprachnachrichten (Standard: ./data/voice relativ zum API-Arbeitsverzeichnis)
# VOICE_STORAGE_DIR=/app/data/voice
