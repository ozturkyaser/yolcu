# Kopieren nach .env im Repository-Root (neben docker-compose.prod.yml):
#   cp infra/digitalocean/env.example .env

# Öffentliche Domain (für Let's Encrypt – muss per DNS auf die Droplet-IP zeigen)
DOMAIN=app.deine-domain.de

# E-Mail für ACME / Let's Encrypt (Zertifikats-Hinweise)
ACME_EMAIL=admin@deine-domain.de

# Postgres (nur intern im Docker-Netz erreichbar)
POSTGRES_PASSWORD=bitte_langen_zufaelligen_wert_eintragen

# API – mindestens 16 Zeichen, in Produktion stark und geheim halten
JWT_SECRET=bitte_mindestens_16_zeichen_zufaellig

# Browser dürfen die API nur von dieser Origin ansprechen (kommagetrennt möglich)
CORS_ORIGIN=https://app.deine-domain.de

# Ortssuche (Nominatim/OSM – Pflichtangabe laut Nutzungsrichtlinie)
GEOCODING_USER_AGENT=YolArkadasim/1.0 (deine@email.de)

# Beim ersten Start true, danach optional false (Migrationen sind idempotent)
INIT_DB=true

# Optional: eigener OSRM
# OSRM_URL=https://router.project-osrm.org

# Optional: KI-Assistent (OpenAI-kompatible API)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Vignetten – Stripe + E-Mail (API-Container)
# STRIPE_SECRET_KEY=sk_live_...
# PUBLIC_WEB_APP_URL=https://app.deine-domain.de
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM="Yol <noreply@deine-domain.de>"
# VIGNETTE_ADMIN_EMAIL=admin@deine-domain.de
