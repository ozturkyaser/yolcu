# Kopie nach `.env` oder `.env.local` und anpassen (nicht committen wenn Geheimnisse drin sind).

# local  = API über relativen Pfad /api (npm run dev: Vite-Proxy → VITE_PROXY_API, default localhost:4000)
# online = feste Remote-URL in VITE_API_BASE_URL (APK, Test gegen Live-Backend, …)
VITE_API_MODE=local

# Nur bei VITE_API_MODE=online nötig: Origin ohne trailing slash, z. B. https://yaser.biz
# VITE_API_BASE_URL=https://yaser.biz

# Optional: nur für `npm run dev` – Ziel des /api-Proxys wenn VITE_API_MODE=local
# VITE_PROXY_API=http://localhost:4000
