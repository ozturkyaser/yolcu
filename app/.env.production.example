# Kopie nach .env.production für Builds, die eine feste API-URL brauchen (z. B. Android-APK).

# Web unter echter Domain: VITE_BASE=/ setzen (oder Docker-Build nutzt das standardmäßig).
# Ohne gesetztes VITE_BASE: ./ für Capacitor/file:-WebView – nicht für reines Webhosting mit /admin.
# VITE_BASE=/

# online = Produktions-API; local = nur /api auf demselben Host (selten für statisches Hosting)
VITE_API_MODE=online

# Ohne trailing slash. Beispiel:
# VITE_API_BASE_URL=https://app.example.com
VITE_API_BASE_URL=

# Optional: Build-Stempel (v.01 …) wenn kein Git-Repo verfügbar ist (z. B. Docker-Image nur mit app/).
# Beispiel aus dem Monorepo-Root: VITE_APP_BUILD_NUMBER=$(git rev-list --count HEAD)
# VITE_APP_BUILD_NUMBER=
